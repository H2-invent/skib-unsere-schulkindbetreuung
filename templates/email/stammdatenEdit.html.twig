{% extends 'email/base.html.twig' %}
{% block header %}
    {% trans %}Änderung der Stammdaten für die Schulkindbetreuung{% endtrans %}
{% endblock %}

{% block content %}
    {% if stadt.translate.emailtemplateStammdatenEdit %}
        {% set eltern = stammdaten %}
        {{ include(template_from_string(stadt.translate.emailtemplateStammdatenEdit)) }}
    {% else %}

        {% if text is defined %}
            <p class="text-center">{{ text }}<br>
        {% endif %}
        <b> {{ 'Guten Tag'|trans }} {{ stammdaten.vorname }} {{ stammdaten.name }}</b> </p>
        {{ include('email/__securityCode.twig') }}

        <p class="text-center">{% trans %}email.anmeldung.edit.main{% endtrans %}
        </p>
        <br>
        <br>
        <p class="text-center">{% trans %}Mit freundlichen Grüßen Ihre betreuende Organisation{% endtrans %}<br>
            <b>{{ organisation.name }}</b></p>

    {% endif %}
{% endblock %}


