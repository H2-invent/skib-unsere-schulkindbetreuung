{% extends 'email/base.html.twig' %}
{% block header %}
    {% trans %}Einmallink für die Anmeldung zur Schulkindbetreuung{% endtrans %}
{% endblock %}

{% block content %}
    <h4 class="text-center">
        {% trans %}Sie wurden soeben für die Anmeldung zur Schulkindbetreuung der {% endtrans %} {{ stadt.name }} {% trans %}freigeschaltet.{% endtrans %}
        <br>
        {% trans %}Nutzen Sie diesen Link um zur Anmeldung zu gelangen. Er ist nur 24 Stunden gültig.{% endtrans %}
    </h4>

    <spacer size="32"></spacer>
    <h5 class="text-center">
        <a href="{{ uri | raw }}">{{ uri | raw }}</a>
    </h5>
    <spacer size="32"></spacer>
{% endblock %}
