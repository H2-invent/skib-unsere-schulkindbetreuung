<div class="modal-header">
    <h5 class="modal-title">
        {% if silent is defined and silent == true %}
            {% trans %}Neuen Vorgänger anlegen (Nur für Autom. Zuweisung!){% endtrans %}
        {% else %}
            {% trans %}Neuen Vorgänger anlegen{% endtrans %}
        {% endif %}
    </h5>
    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
<div class="modal-body">
    {{ form_start(form, {
        'attr': {
            'class':'ajaxForm'
        }
    }) }}
    {{ form_errors(form) }}
    {{ form_row(form.vorganger) }}
    <button type="submit" class="btn btn-primary">{% trans %}Speichern{% endtrans %}</button>
    {% if silent is defined and silent == true %}
        <a class="btn btn-danger" type="DELETE"  href="{{ path('block_schule_linkBlockSilent_remove',{'block_id':block.id}) }}">{{ 'Löschen'|trans }}</a>
    {% else %}
        <a class="btn btn-danger" type="DELETE"  href="{{ path('block_schule_linkBlock_remove',{'block_id':block.id}) }}">{{ 'Löschen'|trans }}</a>
    {% endif %}
    {{ form_end(form) }}
</div>
<script>
    $('.ajaxForm').submit(function (e) {
        e.preventDefault();
        var $form = $(e.currentTarget);
        $.ajax({
            url: $form.attr('action'),
            method: 'POST',
            data: $form.serialize(),
            success: function (data) {
                $.snackbar({content: data.snack});
                $('#loadContentModal').modal('hide');
                $('#blockContent').load(LoadContentUrl)
            }
        });
    });

    $('a[type="DELETE"]').click(function (e) {
        e.preventDefault();
        var $link = $(e.currentTarget);
        $.ajax({
            url: $link.attr('href'),
            method: 'DELETE',
            success: function (data) {
                if (data.snack) {
                    $.snackbar({content: data.snack});
                }
                if (data.redirect) {
                    window.location.href = data.redirect;
                }
            }
        });
    });

    $(function () {
        $("select").attr("size", $("select option").length + 5);
    });
</script>
